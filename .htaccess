# Authorization → PHP (FastCGI / CGI safe passthrough).
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.+)" HTTP_AUTHORIZATION=$1
</IfModule>

# Deny direct access to sensitive project/config files.
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml(\.dist)?|\.env(\..*)?)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block direct web access to Composer dependencies.
    RewriteRule ^vendor(?:/|$) - [F,L]
    # Block direct access to dotfiles like .env, .git, etc.
    # Keep /.well-known/ reachable for ACME and similar standards.
    RewriteRule "(^|/)\.(?!well-known/)" - [F]
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    RewriteRule ^mcp/v1/?$ mcp/v1.php [L,QSA]
    RewriteRule ^terms/?$ terms.php [L,QSA]
    RewriteRule ^policy/?$ policy.php [L,QSA]
</IfModule>
