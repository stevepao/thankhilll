# Authorization → PHP (FastCGI / CGI safe passthrough).
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.+)" HTTP_AUTHORIZATION=$1
</IfModule>

# Disable MultiViews so /mcp/v1 is not negotiated from Accept (avoids 406 with MCP clients).
<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    RewriteRule ^mcp/v1/?$ mcp/v1.php [L,QSA]
</IfModule>
