/vendor/
/node_modules/

# Local environment files
.env
.env.*
!.env.example

# Docker/local runtime data
/docker-data/*
!/docker-data/.gitkeep
!/docker-data/note_media/
/docker-data/note_media/*
!/docker-data/note_media/.gitkeep
!/docker-data/exports/
/docker-data/exports/*
!/docker-data/exports/.gitkeep
/mysql-data/
/db-data/
/backups/
*.sql.gz
*.sql.bz2
*.sql.xz
*.dump

# macOS Finder metadata
.DS_Store

# User-uploaded note photos (keep directory via .gitkeep)
/storage/note_media/*
!/storage/note_media/.gitkeep

# Generated data-export ZIPs (keep .htaccess only)
/storage/exports/*
!/storage/exports/.htaccess
