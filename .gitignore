/vendor/
/node_modules/

# Local environment files
.env
.env.*
!.env.example

# macOS Finder metadata
.DS_Store

# User-uploaded note photos (keep directory via .gitkeep)
/storage/note_media/*
!/storage/note_media/.gitkeep

# Generated data-export ZIPs (keep .htaccess only)
/storage/exports/*
!/storage/exports/.htaccess
