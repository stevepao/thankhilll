# Copy this file to .env and fill in your MySQL credentials.
# Dotenv loads these values into $_ENV for db.php.

DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_mysql_user
DB_PASS=your_mysql_password

# Optional: absolute path where note photos are stored (outside public HTML root in production).
# Default: ./storage/note_media under the project directory.
# NOTE_MEDIA_STORAGE_PATH=/var/www/thankhill-private/note_media

# Google OpenID Connect (OIDC)
GOOGLE_OIDC_CLIENT_ID=your_google_client_id
GOOGLE_OIDC_CLIENT_SECRET=your_google_client_secret
GOOGLE_OIDC_REDIRECT_URI=http://localhost:8000/auth/google/callback.php

# Optional: force Secure session cookies when HTTPS is not detected (e.g. TLS-terminated proxy). Use true or 1.
# SESSION_COOKIE_SECURE=1

# SMTP (PHPMailer) — email OTP sign-in / future notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Gratitude Journal
# Production: use tls (port 587) or ssl (465). Leaving empty disables explicit TLS (local/dev only).
SMTP_SECURE=tls

# diag.php always runs a DB ping; delete diag.php after troubleshooting.
#
# Temporary Today debug (logged-in browser): INDEX_PROBE_SECRET=... then /index_probe.php?key=...
# INDEX_PROBE_SECRET=generate-a-long-random-string-here

# Web Push (server uses minishlink/web-push; PHP 8.2+; extensions: openssl, curl, mbstring, json)
# VAPID key information for push notifications
VAPID_PUBLIC_KEY=BKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=yGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@yourdomain.com
# Allow HTTP delivery to push endpoints (default off when unset). Tests should leave this unset/false.
# PUSH_SENDING_ENABLED=true
# Optional: queue encrypt only, never flush (also skips network when combined with sending disabled).
# PUSH_DIAGNOSTIC_DRY_RUN=true

# Optional absolute origin for Web Push deep links and MCP gateway hints (APP_BASE_URL/mcp/v1 in Save in 1Password). No trailing slash. If unset, derived from the current request.
# APP_BASE_URL=https://your-domain.com


# For cron job
CRON_SECRET=…
